<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Authentication</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Authentication.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">

    <div class="d-flex" style="min-height: 100vh;">
    
        <div class="bg-light border-end d-flex flex-column" style="width: 250px;">
            <div class="p-3 flex-grow-1">
                <h4>Authentication</h4>
                <hr />
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Account" asp-action="PaginaInicial">Página Inicial</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Account" asp-action="Dashboard">Dashboard</a>
                    </li>
                </ul>
            </div>

            <div class="p-3 border-top">

                <a asp-action="Login" asp-controller="Account" class=" btn w-100 mb-2">Login</a>
                <a asp-action="Register" asp-controller="Account" class=" btn w-100 mb-2">Register</a>
    
                <form asp-action="Logout" asp-controller="Account" method="post">
                    <button type="submit" class=" btn w-100 mb-2">Logout</button>
                </form>
            </div>
        </div>

        <div class="flex-grow-1 p-4">
            @RenderBody()
        </div>

    </div>

    <footer class="border-top text-muted p-3 mt-auto">
        <div class="container">
            &copy; 2026 - Authentication -
        </div>
    </footer>

</body>
</html>