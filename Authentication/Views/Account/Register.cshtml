@model Authentication.ViewModel.RegisterViewModel

@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_RegisterLayout.cshtml";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <form class="p-4 border rounded shadow bg-white" style="width: 350px;" asp-action="Register" asp-controller="Account" method="post">
        <h4 class="text-center mb-4">Register</h4>

        <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
        <div class="mb-3">
            <label asp-for="Email" class="form-label">Email</label>
            <input asp-for="Email" type="email" name="Email" class="form-control">
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label">Password</label>
            <input asp-for ="Password" type="password" name="Password" class="form-control">
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
            <input asp-for="ConfirmPassword" type="password" name="ConfirmPassword" class="form-control">
            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100">Register</button>

        <a asp-action="Login" asp-controller="Account" class="btn btn-outline-secondary w-100 mt-2">Voltar ao Login</a>
    </form>
</div>
