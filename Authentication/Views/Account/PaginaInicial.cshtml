@if (TempData["AlreadyLoggedIn"] != null)
{
    <div id="alertModal" class="position-fixed top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center bg-dark bg-opacity-50" style="z-index: 9999;">
        <div class="bg-white rounded-4 shadow-lg text-center p-4">

            <h5 class="fw-bold mb-2">Sessão já iniciada</h5>
            <p class="text-muted small mb-4">@TempData["AlreadyLoggedIn"]</p>

            <button class="btn btn-secondary px-4 fw-semibold"
                    onclick="document.getElementById('alertModal').remove()">
                OK
            </button>

        </div>
    </div>
}