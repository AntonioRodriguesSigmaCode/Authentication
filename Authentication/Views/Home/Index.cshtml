@{
    ViewData["Title"] = "Home Page";
	Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<script>
    function myFunction() {
        window.location.href = "PaginaInicial.cshtml";
	}
</script>

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <form class="p-4 border rounded shadow bg-white" style="width: 350px;">
        <h4 class="text-center mb-4">Login</h4>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" class="form-control">
        </div>

        <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" class="form-control">
        </div>

        <div class="mb-3 d-flex justify-content-between align-items-center">
            <div class="form-check">
                <input type="checkbox" class="form-check-input" id="check">
                <label class="form-check-label" for="check">Remember me</label>
            </div>

            <a href="#" class="text-decoration-none small">Forgot Password?</a>
        </div>

        @* <a href="PaginaIncial.cshtml">
            <button class="btn btn-primary w-100">Sign in</button>
        </a> *@

        <a class="nav-link text-dark" asp-controller="Home" asp-action="PaginaInicial">Clica Aqui</a>

    </form>
</div>

